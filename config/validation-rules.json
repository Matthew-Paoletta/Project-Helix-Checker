{
  "version": 4,
  "description": "Helix validation rules from chunk-1 + chunk-2 + chunk-3 docs.",
  "commit_message": {
    "required_regex": [
      "^\\[(sol|f2p|meta|dep)\\]\\s+.+"
    ],
    "forbidden_regex": []
  },
  "changed_files": {
    "forbidden_path_regex": [
      "^.*\\.pem$",
      "^.*\\.key$",
      "^secrets?/.*"
    ],
    "required_path_regex": [
      "^\\.helix/metadata\\.json$"
    ],
    "max_files_changed": 800
  },
  "diff_limits": {
    "min_total_changes": 25,
    "recommended_max_total_changes": 500,
    "max_total_changes": 1000,
    "max_additions": 50000,
    "max_deletions": 50000
  },
  "author": {
    "allowed_logins": []
  },
  "helix": {
    "required_commit_prefixes": ["sol", "f2p", "meta"],
    "allowed_commit_prefixes": ["sol", "f2p", "meta", "dep"],
    "min_commit_count": 3,
    "max_commit_count": 4,
    "required_commit_order": ["sol", "f2p", "meta"],

    "metadata_file": ".helix/metadata.json",
    "metadata_required_fields": [
      "problem_statement",
      "problem_statement_variant",
      "hints",
      "FAIL_TO_PASS",
      "PASS_TO_PASS"
    ],

    "test_path_must_match_regex": "(test|tests|_test\\.|\\.spec\\.|\\.test\\.)",

    "helix_required_files": [
      ".helix/Dockerfile.helix",
      ".helix/run-tests-eval.sh",
      ".helix/metadata.json"
    ],
    "env_setup_allowed_paths": [
      ".helix/Dockerfile.helix",
      ".helix/run-tests-eval.sh",
      ".helix/metadata.json",
      ".github/workflows/build-push-gar.yml",
      ".github/workflows/golden-solution-validation.yml",
      ".github/workflows/helix-validation.yml"
    ],

    "dockerfile_must_include_regex": [
      "git",
      "ca-certificates"
    ],
    "run_tests_eval_forbidden_regex": [
      "\\bdocker\\s+run\\b",
      "\\bdocker\\s+build\\b",
      "\\bdocker\\s+exec\\b"
    ],

    "golden_solution_forbidden_paths_regex": [
      "^\\.helix/Dockerfile\\.helix$",
      "^\\.helix/run-tests-eval\\.sh$"
    ],

    "sol_commit_forbidden_test_path_regex": [
      "(^|/)tests?/",
      "_test\\.",
      "\\.spec\\.",
      "\\.test\\."
    ],

    "f2p_commit_required_test_path_regex": [
      "(^|/)tests?/",
      "_test\\.",
      "\\.spec\\.",
      "\\.test\\."
    ],

    "f2p_weak_test_forbidden_regex": [
      "assert\\s+hasattr\\(",
      "is\\s+not\\s+None\\s*$",
      "^\\s*from\\s+.+\\s+import\\s+.+\\s*$"
    ]
  }
}
